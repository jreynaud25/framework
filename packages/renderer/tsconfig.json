{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": true,
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@framework/types": ["../types/src"],
      "@framework/types/*": ["../types/src/*"]
    }
  },
  "include": ["src/**/*"]
}
