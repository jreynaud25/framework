NEXT_PUBLIC_APP_URL=https://frame-work.app
NEXT_PUBLIC_APP_HOST=frame-work.app

# Supabase Postgres (used by @framework/db)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/framework

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/account
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/account

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BRAND=
STRIPE_PRICE_BRAND_PLUS=

# Resend
RESEND_API_KEY=
RESEND_FROM=team@frame-work.app

# Anthropic (compliance agent)
ANTHROPIC_API_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=framework
R2_PUBLIC_BASE=https://cdn.frame-work.app
